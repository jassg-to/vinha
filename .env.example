# Google OAuth credentials
# Set up at: https://console.cloud.google.com/apis/credentials
# 1. Create a new project (or select existing)
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized redirect URI: http://localhost:8080/auth/callback
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Secret key for session signing and NiceGUI storage
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
STORAGE_SECRET=change-me-to-a-random-secret
